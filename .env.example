# ─── Supabase ───────────────────────────────────────────────────────────────────
# Get these from https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Auth ───────────────────────────────────────────────────────────────────────
# Google OAuth (Supabase Dashboard → Auth → Providers → Google)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Payments ───────────────────────────────────────────────────────────────────
# Active gateway: 'xendit' | 'paymongo' | 'stripe'
NEXT_PUBLIC_PAYMENT_GATEWAY=xendit

# Xendit (https://dashboard.xendit.co)
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_SECRET=
XENDIT_BUSINESS_ID=

# PayMongo (https://dashboard.paymongo.com)
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_WEBHOOK_SECRET=

# Stripe (international)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Connect (marketplace payouts)
STRIPE_CONNECT_ACCOUNT_ID=

# ─── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Uznir
NEXT_PUBLIC_DEFAULT_CURRENCY=PHP

# ─── Push Notifications (VAPID) ───────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@uznir.app

# ─── Map (optional, for embedded map tiles) ────────────────────────────────────
NEXT_PUBLIC_MAPTILE_URL=
NEXT_PUBLIC_MAPTILE_ACCESS_TOKEN=
